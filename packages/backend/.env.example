# Database
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/immobiliare_crm"

# Server
PORT=3001
NODE_ENV=development
APP_RUNTIME=local
JSON_BODY_LIMIT=50mb

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
INTERNAL_JWT_SECRET="your-internal-jwt-secret"
INTERNAL_MFA_WINDOW=1

# Stripe
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"
STRIPE_PRICE_BASE="price_base_plan_id"
STRIPE_PRICE_PRO="price_pro_plan_id"
STRIPE_PRICE_ENTERPRISE="price_enterprise_plan_id"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO/S3 Storage
STORAGE_PROVIDER=minio
STORAGE_AUTO_CREATE_BUCKET=false
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_OWNER_DOCUMENTS_BUCKET=owner-documents
MINIO_INIT_CHECK=false

# Scraping
SCRAPE_TIMEOUT_MS=55000
SCRAPE_RETRIES=1
SCRAPE_RETRY_BACKOFF_MS=1200
SCRAPER_ENABLE_NESTORIA_FALLBACK=true

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM="CRM Immobiliare <noreply@immobiliare-crm.com>"

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Portali Immobiliari API Keys
IMMOBILIARE_API_KEY=your-immobiliare-api-key
IMMOBILIARE_API_URL=https://api.immobiliare.it

IDEALISTA_API_KEY=your-idealista-api-key
IDEALISTA_SECRET=your-idealista-secret
IDEALISTA_API_URL=https://api.idealista.com

WIKICASA_API_KEY=your-wikicasa-api-key
WIKICASA_API_URL=https://api.wikicasa.it

# Google Calendar Integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:3001/api/auth/google/callback

# Monitoring & Logging
LOG_LEVEL=debug
SENTRY_DSN=your-sentry-dsn

# Rate Limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100 
