{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "node_modules/.prisma/**",
          "node_modules/@prisma/**",
          "prisma/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(api|internal)(/.*)?",
      "dest": "/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/internal/reminders/appointments/sweep",
      "schedule": "* * * * *"
    }
  ]
}
