{
  "name": "@immobiliare-crm/backend",
  "version": "1.0.0",
  "description": "Backend API per CRM Immobiliare",
  "main": "dist/main.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "postinstall": "prisma generate",
    "start": "node dist/main.js",
    "start:provisioner": "ts-node src/provisioner.ts",
    "start:dev": "ts-node src/main.ts",
    "start:prod": "node dist/main.js",
    "test": "ts-node test/feeds-regression.ts && ts-node test/portals-compat.ts",
    "test:crm-13-17": "ts-node test/crm-13-17-regression.ts",
    "test:feeds": "ts-node test/feeds-regression.ts",
    "test:portals-compat": "ts-node test/portals-compat.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "node node_modules/ts-node/dist/bin.js prisma/seed.ts",
    "import:legacy:requests": "node scripts/import-legacy-customers-requests.js",
    "import:immobiliare:properties": "node scripts/import-immobiliare-properties.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "playwright": "^1.52.0",
    "prom-client": "^15.0.0",
    "speakeasy": "^2.0.0",
    "stripe": "^14.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.3.1",
    "prisma": "^6.19.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
