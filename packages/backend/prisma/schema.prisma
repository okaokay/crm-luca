  group     ZoneStreetGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User            @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([zoneId, groupId, createdAt])
  @@index([createdById, createdAt])
  @@map("zone_group_work_logs")
}

model ZoneStreetWorkLog {
  id             String            @id @default(cuid())
  agencyId       String
  zoneId         String
