model ZoneStreetMarketSnapshot {
  id                String   @id @default(cuid())
  agencyId          String
  zoneId            String
  streetId          String   @unique
  sourceUrl         String
  marketTitle       String?
  avgPricePerSqm    String?
  avgRangeText      String?
  trendSummary      String?
  trendLongTerm     String?
  houseSummary      String?
  apartmentSummary  String?
  cityAverageTitle  String?
  lat               Float?
  lng               Float?
  rawPayload        Json?
  fetchedAt         DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  agency Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  zone   AgentZone  @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  street ZoneStreet @relation(fields: [streetId], references: [id], onDelete: Cascade)

  @@index([zoneId, fetchedAt])
  @@map("zone_street_market_snapshots")
}

model ZoneStreetListingSnapshot {
  id         String               @id @default(cuid())
  agencyId   String
  zoneId     String
  groupId    String
  streetId   String
  sourceUrl  String
  status     ListingSnapshotStatus @default(SUCCESS)
  warning    String?
  fetchedAt  DateTime             @default(now())
  expiresAt  DateTime
  rawPayload Json?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  agency   Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  zone     AgentZone       @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  group    ZoneStreetGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  street   ZoneStreet      @relation(fields: [streetId], references: [id], onDelete: Cascade)
  listings ZoneStreetListing[]

  @@index([streetId, fetchedAt])
  @@index([zoneId, groupId, fetchedAt])
  @@map("zone_street_listing_snapshots")
}

model ZoneStreetListing {
  id              String                @id @default(cuid())
  agencyId        String
  zoneId          String
  groupId         String?
  streetId        String
  snapshotId      String?
  sourceListingId String
  sourceUrl       String
  listingUrl      String
  title           String?
  priceText       String?
  surfaceText     String?
  roomsText       String?
  floorText       String?
  description     String?
  energyClass     String?
  addressText     String?
  agencyName      String?
  phoneVisible    String?
  mainImageUrl    String?
  listingStatus   ZoneStreetListingStatus @default(NEW)
  isActive        Boolean               @default(true)
  firstSeenAt     DateTime              @default(now())
  lastSeenAt      DateTime              @default(now())
  metadata        Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  agency    Agency                    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  zone      AgentZone                 @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  group     ZoneStreetGroup?          @relation(fields: [groupId], references: [id], onDelete: SetNull)
  street    ZoneStreet                @relation(fields: [streetId], references: [id], onDelete: Cascade)
  snapshot  ZoneStreetListingSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  actions   ZoneStreetListingAction[]
  assignmentHistory ZoneStreetListingAssignmentHistory[]

  @@unique([streetId, sourceListingId])
  @@index([zoneId, groupId, streetId])
  @@index([streetId, isActive, lastSeenAt])
  @@map("zone_street_listings")
}

model ZoneStreetListingAction {
  id           String            @id @default(cuid())
  agencyId     String
  zoneId       String
  groupId      String?
  streetId     String
  listingId    String
  createdById  String
  actionType   ListingActionType @default(NOTE)
  title        String?
  content      String
  outcome      String?
  nextActionAt DateTime?
  metadata     Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  agency    Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  zone      AgentZone         @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  group     ZoneStreetGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  street    ZoneStreet        @relation(fields: [streetId], references: [id], onDelete: Cascade)
  listing   ZoneStreetListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdBy User              @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
  @@index([streetId, createdAt])
  @@map("zone_street_listing_actions")
}

model ZoneStreetListingAssignmentHistory {
  id          String   @id @default(cuid())
  agencyId    String
  zoneId      String
  groupId     String?
  streetId    String
  listingId   String
  fromAgentId String?
  toAgentId   String
  assignedAt  DateTime @default(now())
  note        String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agency    Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  zone      AgentZone         @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  group     ZoneStreetGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  street    ZoneStreet        @relation(fields: [streetId], references: [id], onDelete: Cascade)
  listing   ZoneStreetListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  fromAgent User?             @relation("ZoneStreetListingAssignmentFrom", fields: [fromAgentId], references: [id], onDelete: SetNull)
  toAgent   User              @relation("ZoneStreetListingAssignmentTo", fields: [toAgentId], references: [id], onDelete: Cascade)

  @@index([listingId, assignedAt])
  @@index([zoneId, groupId, streetId, assignedAt])
  @@map("zone_street_listing_assignment_history")
}

model ApimoRecord {
  id            String         @id @default(cuid())
  entityType    ApimoEntityType
  apimoId       String
  payload       Json
  localEntityId String?
  lastPulledAt  DateTime?
  lastPushedAt  DateTime?
  lastError     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  agencyId      String
  agency        Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, entityType, apimoId])
  @@index([agencyId, entityType])
  @@map("apimo_records")
}

model InternalUser {
  id           String           @id @default(cuid())
  email        String           @unique
  passwordHash String
  role         InternalUserRole
  mfaSecret    String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("internal_users")
}
