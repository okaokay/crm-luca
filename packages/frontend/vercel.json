{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://backend-delta-two-35.vercel.app/api/$1"
    },
    {
      "source": "/internal/(.*)",
      "destination": "https://backend-delta-two-35.vercel.app/internal/$1"
    },
    {
      "source": "/feeds/(.*)",
      "destination": "https://backend-delta-two-35.vercel.app/feeds/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
