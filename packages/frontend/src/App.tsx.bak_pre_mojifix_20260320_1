              properties={properties}

              contacts={contacts}

              dataLoading={dataLoading}

              onNavigateToProperty={(propertyId) => {

                setCurrentPropertyId(propertyId)

                setCurrentPage('property-detail')

              }}

              onCreateContact={handleCreateContact}

              onCreateProperty={handleCreateProperty}

              agents={agents}

              onLoadDocuments={loadContactDocuments}

              onUploadDocument={uploadContactDocument}

              onDeleteDocument={deleteContactDocument}

              canManageAssignments={userRole === 'SUPER_ADMIN' || userRole === 'AGENCY_ADMIN'}

            />

          )}

          {currentPage === 'agenti' && (userRole === 'SUPER_ADMIN' || userRole === 'AGENCY_ADMIN') && (

            <AgentsPage

              agents={agents}

              dataLoading={dataLoading}

              onRefreshData={fetchData}

              onViewProperty={(propertyId) => {

                setCurrentPropertyId(propertyId)

                setCurrentPage('property-detail')

              }}

            />

          )}

          {currentPage === 'agenti' && userRole !== 'SUPER_ADMIN' && userRole !== 'AGENCY_ADMIN' && (

            <div>Non autorizzato</div>

          )}

          {currentPage === 'zone-tasks' && (

            <AgentZoneTasksPage agents={agents} />

          )}

          {currentPage === 'appuntamenti' && (

            <AppointmentsPage

              appointments={appointments}

              dataLoading={dataLoading}

              onCreateAppointment={handleCreateAppointment}

              onUpdateAppointment={handleUpdateAppointment}

              onDeleteAppointment={handleDeleteAppointment}

              agents={agents}

              contacts={contacts}

              properties={properties}

              onCreateContact={handleCreateContact}

              onCreateProperty={handleCreateProperty}

              currentUserRole={userRole}

              currentUserId={user?.id ?? null}

            />

          )}

          {currentPage === 'contratti' && (

            <ContractsPage

              contracts={contracts}

              contractTemplates={contractTemplates}

              properties={properties}

              contacts={contacts}

              agents={agents}

              onSave={handleSaveContract}

              onDelete={handleDeleteContract}

            />

          )}

          {currentPage === 'attivita' && (

            <ActivitiesPage

              activities={activities}

              dataLoading={dataLoading}

              onCompleteActivity={handleCompleteActivity}

              onCreateActivity={handleCreateActivity}

              onUpdateActivity={handleUpdateActivity}

              onDeleteActivity={handleDeleteActivity}

              currentUserRole={userRole}

              currentUserId={user?.id ?? null}

            />

          )}

          {currentPage === 'report' && <ReportPage stats={stats} properties={properties} contacts={contacts} />}

          {currentPage === 'portals' && (

            userRole === 'SUPER_ADMIN' || userRole === 'AGENCY_ADMIN' ? (

              <PortalsPage

                portals={portals}

                loading={portalsLoading}

                onSelectPortal={(portalId) => {

                  navigate(`/portals/${encodeURIComponent(portalId)}`)

                }}

                onTogglePortal={handleTogglePortal}

                onSetPortalActiveLocal={setPortalActiveLocal}

                onSetPortalActivationStatusLocal={setPortalActivationStatusLocal}

                canToggle={userRole === 'SUPER_ADMIN' || userRole === 'AGENCY_ADMIN'}

              />

            ) : (

              <div>Non autorizzato</div>

            )

          )}

          {currentPage === 'portal-detail' && currentPortalId && (

            userRole === 'SUPER_ADMIN' || userRole === 'AGENCY_ADMIN' ? (

              <PortalDetailPage

                portalId={currentPortalId}

                portals={portals}

                loading={portalsLoading}

                agents={agents}

                onBack={() => {

                  navigate('/portals')

                  setCurrentPage('portals')

                }}

                onOpenProperty={(propertyId) => {

                  setCurrentPropertyId(propertyId)

                  setCurrentPage('property-detail')

                }}

              />

            ) : (

              <div>Non autorizzato</div>

            )

          )}

          {currentPage === 'notifiche' && (

            <NotificationsPage

              notifications={notifications}

              onMarkAsRead={(notificationId) => {

                markNotificationAsRead(notificationId)

              }}

              onMarkAllAsRead={() => {

                markAllNotificationsAsRead()

              }}

              onDeleteNotification={(notificationId) => {

                deleteNotification(notificationId)

              }}

              isAdmin={userRole === 'SUPER_ADMIN' || userRole === 'AGENCY_ADMIN'}

              agents={agents}

              selectedUserId={notificationsUserFilter}

              onChangeSelectedUserId={setNotificationsUserFilter}

            />

          )}

          {currentPage === 'impostazioni' && <SettingsPage onRefreshData={fetchData} createNotification={createNotification} />}

            </div>

          </div>

        </main>

      </div>

    </div>

  )

}



type PortalsPageProps = {

  portals: PortalSummary[]

  loading: boolean

  onSelectPortal: (portalId: string) => void

  onTogglePortal: (portalId: string, nextActive: boolean) => void

  onSetPortalActiveLocal: (portalId: string, nextActive: boolean) => void

  onSetPortalActivationStatusLocal: (

    portalId: string,

    nextStatus: PortalSummary['activationStatus'] | null

  ) => void

  canToggle: boolean

}



export function PortalsPage({

  portals,

  loading,

  onSelectPortal,

  onTogglePortal,

  onSetPortalActiveLocal,

  onSetPortalActivationStatusLocal,

  canToggle

}: PortalsPageProps) {

  const activePortals = portals.filter((p) => p.active)

  const inactivePortals = portals.filter((p) => !p.active)



  const { token, logout } = useAuthStore()

  const navigate = useNavigate()

  const [configDashboardLoading, setConfigDashboardLoading] = useState(false)

  const [configDashboardError, setConfigDashboardError] = useState<string | null>(null)

  const [incompleteConfigPortals, setIncompleteConfigPortals] = useState(0)

  const [portalConfigIssues, setPortalConfigIssues] = useState<Record<string, boolean>>({})

  const [centralPortalStatus, setCentralPortalStatus] = useState<Record<string, 'ACTIVE' | 'INACTIVE'>>({})

  const [centralPortalLoading, setCentralPortalLoading] = useState<Record<string, boolean>>({})

  const [activationRequestLoading, setActivationRequestLoading] = useState<Record<string, boolean>>({})



  const totalOnlineFeedAds = portals

    .filter((p) => p.kind === 'FEED_PULL')

    .reduce((sum, p) => sum + (p.publishedCount || 0), 0)



  const totalErrorProperties = portals.reduce((sum, p) => sum + (p.errorCount || 0), 0)



  useEffect(() => {

    if (!token) return



    const relevantPortals = portals.filter(

      (p) =>

        p.implemented &&

        (p.id === 'IMMOBILIARE_IT' || p.id === 'GESTIONALE_IMMOBILIARE_IT' || p.id === 'APIMO_NET')

    )



    if (!relevantPortals.length) {

      setIncompleteConfigPortals(0)

      setConfigDashboardError(null)

      setConfigDashboardLoading(false)

      return

    }



    let cancelled = false



    const loadConfigStatus = async () => {

      setConfigDashboardLoading(true)

      setConfigDashboardError(null)



      try {

        const headers: HeadersInit = { Authorization: `Bearer ${token}` }

        let incomplete = 0

        const nextIssues: Record<string, boolean> = {}



        if (relevantPortals.some((p) => p.id === 'IMMOBILIARE_IT')) {

          try {

            const response = await fetch('/api/config/immobiliareit', { headers })



            if (response.status === 401) {

              logout()

              navigate('/login')

              return

            }



            const payload = await response.json().catch(() => null)

            if (!response.ok || !payload?.success) {

              incomplete += 1

              nextIssues['IMMOBILIARE_IT'] = true

            } else {

              const data = payload.data || {}

              const configured = Boolean(

                data.immoUsername &&

                  data.immoSource &&

                  data.immoEndpoint &&

                  data.hasPassword === true

              )



              if (!configured) {

                incomplete += 1

                nextIssues['IMMOBILIARE_IT'] = true

              }

            }

          } catch {

            incomplete += 1

            nextIssues['IMMOBILIARE_IT'] = true

          }

        }



        if (relevantPortals.some((p) => p.id === 'GESTIONALE_IMMOBILIARE_IT')) {

          try {

            const response = await fetch('/api/config/gestionaleimmobiliare', { headers })



            if (response.status === 401) {

              logout()

              navigate('/login')

              return

            }



            const payload = await response.json().catch(() => null)

            if (!response.ok || !payload?.success) {

              incomplete += 1

              nextIssues['GESTIONALE_IMMOBILIARE_IT'] = true

            } else {

              const data = payload.data || {}

              const rawAgencyId =

                data.giAgencyId == null || data.giAgencyId === ''

                  ? ''

                  : String(data.giAgencyId)

              const configured = rawAgencyId.trim() !== ''



              if (!configured) {

                incomplete += 1

                nextIssues['GESTIONALE_IMMOBILIARE_IT'] = true

              }

            }

          } catch {

            incomplete += 1

            nextIssues['GESTIONALE_IMMOBILIARE_IT'] = true

          }

        }



        if (relevantPortals.some((p) => p.id === 'APIMO_NET')) {

          try {

            const response = await fetch('/api/sync/apimo/status', { headers })



            if (response.status === 401) {

              logout()

              navigate('/login')

              return

            }



            const payload = await response.json().catch(() => null)

            if (!response.ok || !payload?.success) {

              incomplete += 1

              nextIssues['APIMO_NET'] = true

            } else {

              const data = payload.data || {}

              const configured = Boolean(data.configured)



              if (!configured) {

                incomplete += 1

                nextIssues['APIMO_NET'] = true

              }

            }

          } catch {

            incomplete += 1

            nextIssues['APIMO_NET'] = true

          }

        }



        if (cancelled) {

          return

        }



        setIncompleteConfigPortals(incomplete)

        setPortalConfigIssues(nextIssues)

        setConfigDashboardLoading(false)

      } catch {

        if (cancelled) {

          return

        }



        setConfigDashboardError('Errore nel caricamento configurazioni portali')

        setConfigDashboardLoading(false)

      }

    }



    loadConfigStatus()



    return () => {

      cancelled = true

    }

  }, [portals, token, logout, navigate])



  useEffect(() => {

    if (!token) {

      setCentralPortalStatus({})

      return

    }



    let cancelled = false



    const loadCentralPortals = async () => {

      try {

        const headers: HeadersInit = { Authorization: `Bearer ${token}` }

        const response = await fetch('/agency/portals', { headers })



        if (response.status === 401) {

          logout()

          navigate('/login')

          return

        }



        const payload = await response.json().catch(() => null)

        if (!response.ok || !payload?.success || !payload.data?.portals || cancelled) {

          return

        }



        const items = Array.isArray(payload.data.portals) ? payload.data.portals : []

        const nextStatus: Record<string, 'ACTIVE' | 'INACTIVE'> = {}

        for (const item of items) {

          const id = typeof item.id === 'string' ? item.id : typeof item.portalId === 'string' ? item.portalId : ''

          if (!id) continue

          const raw = typeof item.status === 'string' ? item.status.toUpperCase() : ''

          const status = raw === 'ACTIVE' ? 'ACTIVE' : 'INACTIVE'

          nextStatus[id] = status

        }



        if (!cancelled) {

          setCentralPortalStatus(nextStatus)

        }

      } catch {

        return

      }

    }



    loadCentralPortals()



    return () => {

      cancelled = true

    }

  }, [token, logout, navigate])



  const pillStyle: React.CSSProperties = {

    fontSize: '0.75rem',

    padding: '0.25rem 0.5rem',

    borderRadius: '9999px',

    backgroundColor: '#f3f4f6',

    color: '#4b5563'

  }



  const handleRequestActivation = async (portal: PortalSummary) => {

    if (!token) return

    if (activationRequestLoading[portal.id]) return



    try {

      setActivationRequestLoading(prev => ({

        ...prev,

        [portal.id]: true

      }))



      const response = await fetch(`/agency/portals/${encodeURIComponent(portal.id)}/request-activation`, {

        method: 'POST',

        headers: {

          Authorization: `Bearer ${token}`,

          'Content-Type': 'application/json'

        },

        body: JSON.stringify({})

      })



      if (response.status === 401) {

        logout()

        navigate('/login')

        return

      }



      const payload = await response.json().catch(() => null)

      if (!response.ok || !payload?.success) {

        alert(payload?.message || 'Errore durante la richiesta di attivazione del portale')

        return

      }



      onSetPortalActivationStatusLocal(portal.id, 'OPEN')

    } catch {

      alert('Errore di rete durante la richiesta di attivazione del portale')

    } finally {

      setActivationRequestLoading(prev => {

        const next = { ...prev }

        delete next[portal.id]

        return next

      })

    }

  }



  const handleToggleCentralPortal = async (portalId: string, currentActive: boolean) => {

    if (!token) return



    if (centralPortalLoading[portalId]) return



    const currentStatus = centralPortalStatus[portalId] || (currentActive ? 'ACTIVE' : 'INACTIVE')

    const nextStatus: 'ACTIVE' | 'INACTIVE' = currentStatus === 'ACTIVE' ? 'INACTIVE' : 'ACTIVE'



    try {

      setCentralPortalLoading(prev => ({

        ...prev,

        [portalId]: true

      }))



      const response = await fetch(`/agency/portals/${encodeURIComponent(portalId)}`, {

        method: 'PATCH',

        headers: {

          Authorization: `Bearer ${token}`,

          'Content-Type': 'application/json'

        },

        body: JSON.stringify({ status: nextStatus })

      })



      if (response.status === 401) {

        logout()

        navigate('/login')

        return

      }



      const payload = await response.json().catch(() => null)

      if (!response.ok || !payload?.success) {

        alert(payload?.message || "Errore durante l'aggiornamento dello stato del portale centralizzato")

        return

      }



      setCentralPortalStatus(prev => ({

        ...prev,

        [portalId]: nextStatus

      }))



      const nextActive = nextStatus === 'ACTIVE'

      onSetPortalActiveLocal(portalId, nextActive)

    } catch {

      alert("Errore di rete durante l'aggiornamento dello stato del portale centralizzato")

    } finally {

      setCentralPortalLoading(prev => {

        const next = { ...prev }

        delete next[portalId]

        return next

      })

    }

  }



  const renderList = (items: PortalSummary[]) => {

    if (!items.length) {

      return (

        <p style={{ color: '#6b7280', fontSize: '0.875rem' }}>

          Nessun portale in questa sezione.

        </p>

      )

    }



    return (

      <div

        style={{

          display: 'grid',

          gridTemplateColumns: 'repeat(auto-fit, minmax(260px, 1fr))',

          gap: '1rem'

        }}

      >

        {items.map((portal) => {

          const hasMetrics =

            typeof portal.selectedCount === 'number' ||

            typeof portal.publishedCount === 'number' ||

            typeof portal.errorCount === 'number'



          const isCentral = centralPortalStatus[portal.id] !== undefined

          const isCentralLoading = isCentral && centralPortalLoading[portal.id] === true

          const hasActivationRequest =

            portal.activationStatus === 'OPEN' || portal.activationStatus === 'IN_PROGRESS'

          const canRequestActivation =

            !isCentral &&

            portal.kind === 'MANUAL' &&

            !hasActivationRequest



          const totalOps = portal.publishedCount + portal.errorCount

          const errorRate = totalOps > 0 ? portal.errorCount / totalOps : 0

          const hasErrorAlert =

            portal.errorCount >= PORTAL_ERROR_ABSOLUTE_THRESHOLD ||

            (portal.errorCount > 0 && errorRate >= PORTAL_ERROR_PERCENT_THRESHOLD)

          const hasConfigIssue = Boolean(portalConfigIssues[portal.id])



          return (

            <div

              key={portal.id}

              role="button"

              tabIndex={0}

              onClick={() => onSelectPortal(portal.id)}

              onKeyDown={(event) => {

                if (event.key === 'Enter' || event.key === ' ') {

                  event.preventDefault()

                  onSelectPortal(portal.id)

                }

              }}

              style={{

                textAlign: 'left',

                padding: '1rem',

                borderRadius: '0.5rem',

                border: '1px solid #e5e7eb',

                backgroundColor: 'white',

                cursor: 'pointer',

                display: 'flex',

                flexDirection: 'column',

                gap: '0.5rem'

              }}

            >

              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', gap: '0.75rem' }}>

                <div>

                  <div style={{ display: 'flex', alignItems: 'center', gap: '0.5rem' }}>

                    <h3 style={{ fontSize: '1rem', fontWeight: 600, color: '#111827' }}>{portal.label}</h3>

                    {hasErrorAlert && (

                      <span

                        style={{

                          fontSize: '0.75rem',

                          padding: '0.125rem 0.5rem',

                          borderRadius: '9999px',

                          backgroundColor: '#fee2e2',

                          color: '#b91c1c',

                          fontWeight: 600

                        }}

                      >

                        ÃƒÂ¢Ã…Â¡Ã‚Â  Errori elevati

                      </span>

                    )}

                    {portal.active && hasConfigIssue && (

                      <span

                        style={{

                          fontSize: '0.75rem',

                          padding: '0.125rem 0.5rem',

                          borderRadius: '9999px',

                          backgroundColor: '#fef9c3',

                          color: '#854d0e',

                          fontWeight: 600

                        }}

                      >

                        ÃƒÂ¢Ã…Â¡Ã‚Â  Configurazione incompleta

                      </span>

                    )}

                  </div>

                  <p style={{ fontSize: '0.875rem', color: '#6b7280' }}>

                    {portal.modeLabel} Ã‚Â· {portal.kind}

                  </p>

                </div>

                <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'flex-end', gap: '0.25rem' }}>

                  <span

                    style={{

                      fontSize: '0.75rem',

                      padding: '0.25rem 0.5rem',

                      borderRadius: '9999px',

                      backgroundColor: portal.implemented ? '#dcfce7' : '#fee2e2',

                      color: portal.implemented ? '#166534' : '#991b1b',

                      fontWeight: 500

                    }}

                  >

                    {portal.implemented ? 'Implementato' : 'Non implementato'}

                  </span>

                  {portal.kind === 'MANUAL' && (

                    <>

                      {portal.activationStatus && (

                        <span

                          style={{

                            fontSize: '0.75rem',

                            padding: '0.25rem 0.5rem',

                            borderRadius: '9999px',

                            backgroundColor:

                              portal.activationStatus === 'COMPLETED'

