    if (portalId === 'FACEBOOK_MARKETPLACE') return { tone: 'error' as const, label: 'ESCLUSO DAL CATALOGO', details: `Manca: ${missing.join(', ')}` }

    if (portalId === 'GESTIONALE_IMMOBILIARE_IT') return { tone: 'error' as const, label: 'ESCLUSO DAL FEED', details: `Manca: ${missing.join(', ')}` }

