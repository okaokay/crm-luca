  const immoLastSyncAt = property.immoLastSyncAt ? new Date(property.immoLastSyncAt).toLocaleString('it-IT') : null

  const metaFeedUrl = portals.find((p) => p.id === 'FACEBOOK_MARKETPLACE')?.feedUrl || null

  const trovitFeedUrl = portals.find((p) => p.id === 'TROVIT_IT')?.feedUrl || null

