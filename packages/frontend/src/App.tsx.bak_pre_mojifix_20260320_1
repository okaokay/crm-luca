  const [agencyActionsError, setAgencyActionsError] = useState<string | null>(null)

  const [agencyActionsLoading, setAgencyActionsLoading] = useState(false)

  const [internalSection, setInternalSection] = useState<'agencies' | 'global-portals' | 'portal-requests' | 'audit-log'>('agencies')

  const [globalPortals, setGlobalPortals] = useState<

    {

