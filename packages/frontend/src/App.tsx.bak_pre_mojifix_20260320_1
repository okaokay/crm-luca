  const [portals, setPortals] = useState<PortalSummary[]>([])

  const [portalsLoading, setPortalsLoading] = useState(false)

  const isMobileLayout = viewportWidth < 1024



  useEffect(() => {

    const onResize = () => setViewportWidth(window.innerWidth)

