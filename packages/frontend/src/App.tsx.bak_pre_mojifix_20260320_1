                <div style={{ display: 'flex', gap: '0.5rem' }}>

                  <button

                    onClick={() => handleView(contact)}

                    style={{

                      display: 'flex',

                      alignItems: 'center',

                      padding: '0.5rem 1rem',

                      backgroundColor: '#3b82f6',

                      color: 'white',

                      border: 'none',

                      borderRadius: '0.375rem',

                      cursor: 'pointer',

                      fontSize: '0.875rem'

                    }}

                  >

                    <Eye size={16} style={{ marginRight: '0.5rem' }} />

                    Apri scheda

                  </button>

                  <button

                    onClick={() => handleEdit(contact)}

                    style={{

                      display: 'flex',

                      alignItems: 'center',

                      padding: '0.5rem 1rem',

                      backgroundColor: '#10b981',

                      color: 'white',

                      border: 'none',

                      borderRadius: '0.375rem',

                      cursor: 'pointer',

                      fontSize: '0.875rem'

                    }}

                  >

                    <Edit size={16} style={{ marginRight: '0.5rem' }} />

                    Modifica

                  </button>

                  <button

                    onClick={() => handleCall(contact)}

                    style={{

                      display: 'flex',

                      alignItems: 'center',

                      padding: '0.5rem 1rem',

                      backgroundColor: '#6b7280',

                      color: 'white',

                      border: 'none',

                      borderRadius: '0.375rem',

                      cursor: 'pointer',

                      fontSize: '0.875rem'

                    }}

                  >

                    <Phone size={16} style={{ marginRight: '0.5rem' }} />

                    Chiama

