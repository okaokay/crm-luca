// Dashboard

function DashboardPage({

  stats,

  dataLoading,

  properties,

  agents,

  canManageAssignments,
  currentUserRole,

  onOpenProperty,

  onOpenAppointments,

  onCreateContact,

  onCreateProperty,

  onCreateActivity,

  onLoadDocuments,

  onUploadDocument,

  onDeleteDocument

}: {

  stats: DashboardStats | null

  dataLoading: boolean

  properties: Property[]

  agents: Agent[]

  canManageAssignments: boolean

  currentUserRole?: 'SUPER_ADMIN' | 'AGENCY_ADMIN' | 'AGENT' | 'COLLABORATOR' | null

  onOpenProperty: (propertyId: string) => void

  onOpenAppointments: () => void

  onCreateContact: (contact: Omit<Contact, 'id' | 'createdAt'>) => Promise<Contact | null>

  onCreateProperty: (property: Omit<Property, 'id' | 'createdAt'>) => Promise<Property | null>

  onCreateActivity: (activity: any) => Promise<any>

  onLoadDocuments: (contactId: string) => Promise<OwnerDocument[]>

  onUploadDocument: (

    contactId: string,

    payload: { file: File; type: string; side?: string }

  ) => Promise<OwnerDocument | null>

  onDeleteDocument: (contactId: string, documentId: string) => Promise<boolean>

}) {

  const [searchTerm, setSearchTerm] = useState('')

  const [showSearchResults, setShowSearchResults] = useState(false)

  const [showClientRequestModal, setShowClientRequestModal] = useState(false)

  const [showPropertyModal, setShowPropertyModal] = useState(false)

  const [showTaskModal, setShowTaskModal] = useState(false)

  const [taskSaving, setTaskSaving] = useState(false)

  const [taskForm, setTaskForm] = useState({

    title: '',

    description: '',

    type: 'TASK',

    dueDate: new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString().split('T')[0],

    priority: 2,
    assignedToId: ''

  })

  const searchBoxRef = React.useRef<HTMLDivElement | null>(null)
  const { user: loggedUser } = useAuthStore()
  const resolvedRole = String(currentUserRole || loggedUser?.role || '').toUpperCase()
  const isAdminUser =
    canManageAssignments ||
    resolvedRole === 'SUPER_ADMIN' ||
    resolvedRole === 'AGENCY_ADMIN' ||
    resolvedRole === 'OWNER' ||
    resolvedRole === 'OPS_ADMIN'



  useEffect(() => {

    const handleClickOutside = (event: MouseEvent) => {

      const target = event.target as Node

      if (searchBoxRef.current && !searchBoxRef.current.contains(target)) {

        setShowSearchResults(false)

      }

    }

    document.addEventListener('mousedown', handleClickOutside)

    return () => document.removeEventListener('mousedown', handleClickOutside)

  }, [])



  const safeNumber = (value: unknown) => {

    if (typeof value === 'number' && !Number.isNaN(value)) {

      return value

    }

    if (typeof value === 'string') {

      const parsed = Number(value)

      if (!Number.isNaN(parsed)) return parsed

    }

    return 0

  }



  const filteredProperties = searchTerm.trim()

    ? properties

        .filter((property) => {

          const title = property.title?.toLowerCase() || ''

          const reference = property.reference?.toLowerCase() || ''

          const query = searchTerm.toLowerCase()

          return title.includes(query) || reference.includes(query)

        })

        .slice(0, 8)

    : []



  const statsData = stats ?? {

    totalProperties: 0,

    availableProperties: 0,

    reservedProperties: 0,

    soldProperties: 0,

    totalContacts: 0,

    activeContacts: 0,

    buyers: 0,

    sellers: 0,

    totalAppointments: 0,

    scheduledAppointments: 0,

    totalActivities: 0,

    pendingActivities: 0,

    completedActivities: 0,

    averagePropertyPrice: 0

  }



  const topStats = [

    { label: 'Immobili', value: safeNumber(statsData.totalProperties), icon: Building },

    { label: 'Disponibili', value: safeNumber(statsData.availableProperties), icon: Home },

    { label: 'Clienti', value: safeNumber(statsData.totalContacts), icon: Users },

    { label: 'Task Pendenti', value: safeNumber(statsData.pendingActivities), icon: CheckSquare }

  ]



  const handleQuickTaskSubmit = async (e: React.FormEvent) => {

    e.preventDefault()

    if (!taskForm.title.trim()) {

      alert('Titolo task obbligatorio')

      return

    }

    if (isAdminUser && !taskForm.assignedToId) {

      alert('Seleziona l\'agente a cui assegnare il task')

      return

    }

    setTaskSaving(true)

    try {

      await onCreateActivity({

        ...taskForm,

        assignedToId: isAdminUser ? taskForm.assignedToId : (loggedUser?.id || taskForm.assignedToId),

        completed: false,

        tags: []

      })

      setShowTaskModal(false)

      setTaskForm({

        title: '',

        description: '',

        type: 'TASK',

        dueDate: new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString().split('T')[0],

        priority: 2,

        assignedToId: ''

      })

    } finally {

      setTaskSaving(false)

    }

  }



  if (dataLoading) {

    return <div>Caricamento dashboard...</div>

  }



  return (

    <div style={{ display: 'grid', gap: '1.35rem' }}>

      <section

        style={{

          borderRadius: '1.1rem',

          background: 'linear-gradient(160deg, #16181f 0%, #232734 100%)',

          border: '1px solid rgba(148,163,184,0.24)',

          padding: '2rem 1.25rem',

          color: '#e2e8f0',

          display: 'grid',

          placeItems: 'center'

        }}

