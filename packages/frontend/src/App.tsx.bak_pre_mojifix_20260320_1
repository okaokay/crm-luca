function PropertiesPage({

  properties,

  contacts,

  dataLoading,

  user,

  onRefreshData,

  onViewProperty,

  setNotifications,

  setUnreadNotifications,

  setShowNotifications

}: {

  properties: Property[]

  contacts: Contact[]

  dataLoading: boolean

  user: User | null

  onRefreshData: () => void

  onViewProperty: (propertyId: string) => void

  setNotifications: React.Dispatch<React.SetStateAction<Notification[]>>

  setUnreadNotifications: React.Dispatch<React.SetStateAction<number>>

  setShowNotifications: React.Dispatch<React.SetStateAction<boolean>>

}) {

  const [searchTerm, setSearchTerm] = useState('')

  const [filterType, setFilterType] = useState('')

  const [filterStatus, setFilterStatus] = useState('')
  const [filterContractType, setFilterContractType] = useState('')
  const [filterReference, setFilterReference] = useState('')
  const [filterCity, setFilterCity] = useState('')
  const [filterProvince, setFilterProvince] = useState('')
  const [filterZipCode, setFilterZipCode] = useState('')
  const [filterEnergyClass, setFilterEnergyClass] = useState('')
  const [filterCondition, setFilterCondition] = useState('')
  const [filterMinPrice, setFilterMinPrice] = useState('')
  const [filterMaxPrice, setFilterMaxPrice] = useState('')
  const [filterMinSurface, setFilterMinSurface] = useState('')
  const [filterMaxSurface, setFilterMaxSurface] = useState('')
  const [filterMinRooms, setFilterMinRooms] = useState('')
  const [filterMinBedrooms, setFilterMinBedrooms] = useState('')
  const [filterMinBathrooms, setFilterMinBathrooms] = useState('')

  const [showCreateModal, setShowCreateModal] = useState(false)

  const [editingProperty, setEditingProperty] = useState<Property | null>(null)

  const [showViewModal, setShowViewModal] = useState<Property | null>(null)

  const { token } = useAuthStore()
  if (dataLoading) {

    return <div>Caricamento immobili...</div>

  }



  // Gestione CRUD immobili

  const handleCreateProperty = async (propertyData: Omit<Property, 'id' | 'createdAt'>) => {

    // Inject agencyId from current user context

    // FIX: Ensure user is defined safely to avoid ReferenceError

    const currentUser = user;



    const payload = {

      ...propertyData,

      agencyId: currentUser?.agency?.id,

      ownerId: propertyData.agentId || currentUser?.id

    }

    console.log('handleCreateProperty payload:', payload)

    

    try {

      const authHeaders: HeadersInit = token ? { Authorization: `Bearer ${token}` } : {}

      const response = await fetch('/api/properties', {

        method: 'POST',

        headers: { 'Content-Type': 'application/json', ...authHeaders },

        body: JSON.stringify(payload)

      })



      const data = await response.json()

      if (data.success) {

        setShowCreateModal(false)

        onRefreshData() // Ricarica i dati



        // AUTO-MATCHING

        const createdProperty = (data.data || { ...propertyData, id: `${Date.now()}` }) as Property

        const matches = contacts

          .filter(c => c.category === 'CLIENT' && (c.type === 'BUYER' || c.type === 'TENANT'))

          .map(client => ({ client, ...calculateMatchingScore(createdProperty, client) }))

          .filter(m => m.score >= 50)

          .sort((a, b) => b.score - a.score)



        if (matches.length > 0) {

          // Add notification

          const newNotification: Notification = {

            id: Date.now().toString(),

            title: 'ðŸŽ¯ Nuovi Match Trovati!',

            message: `Trovati ${matches.length} clienti compatibili per "${createdProperty.title}". Top match: ${matches[0].client.firstName} ${matches[0].client.lastName} (${matches[0].score}%)`,

            type: 'MATCH_FOUND',

            isRead: false,

            createdAt: new Date().toISOString(),

            relatedId: createdProperty.id,

            data: { propertyId: createdProperty.id, clientId: matches[0].client.id }

          }

          setNotifications(prev => [newNotification, ...prev])

          setUnreadNotifications(prev => prev + 1)



          // Show custom modal/toast (simulated by opening notification dropdown if implemented, or just alert for now but styled)

          // For now, we'll rely on the bell icon showing the badge, but the user asked for a "modal style facebook".

          // We will trigger a state to open the notification dropdown automatically.

          setShowNotifications(true)

        } else {

          alert('Ã¢Å“â€¦ Immobile creato con successo!')

        }

      } else {

        alert('Errore nella creazione: ' + data.message + (data.error ? '\n\nDettagli: ' + data.error : ''))

      }

    } catch (error) {

      console.error('Errore creazione immobile:', error)

      alert('Errore di connessione')

    }

  }



  const handleUpdateProperty = async (id: string, propertyData: Partial<Property>) => {

    console.log('handleUpdateProperty payload:', propertyData)

    try {

      const authHeaders: HeadersInit = token ? { Authorization: `Bearer ${token}` } : {}

      const response = await fetch(`/api/properties/${id}`, {

        method: 'PUT',

        headers: { 'Content-Type': 'application/json', ...authHeaders },

        body: JSON.stringify(propertyData)

      })



      const data = await response.json()

      if (data.success) {

        setEditingProperty(null)

        onRefreshData()

        alert('Immobile aggiornato con successo!')

      } else {

        alert('Errore nell\'aggiornamento: ' + data.message + (data.error ? '\n\nDettagli: ' + data.error : ''))

      }

    } catch (error) {

      console.error('Errore aggiornamento immobile:', error)

      alert('Errore di connessione')

    }

  }



  const handleDeleteProperty = async (id: string, title: string) => {

    if (!confirm(`Sei sicuro di voler eliminare l'immobile "${title}"?`)) {

      return

    }



    try {

      const authHeaders: HeadersInit = token ? { Authorization: `Bearer ${token}` } : {}

      const response = await fetch(`/api/properties/${id}`, {

        method: 'DELETE',

        headers: authHeaders

      })

      const data = await response.json()

      if (data.success) {

        onRefreshData()

        alert('Immobile eliminato con successo!')

      } else {

        alert('Errore nell\'eliminazione: ' + data.message)

      }

    } catch (error) {

      console.error('Errore eliminazione immobile:', error)

      alert('Errore di connessione')

    }

  }

  const isPendingApproval = (property: Partial<Property>) =>
    typeof property.notes === 'string' && property.notes.includes('[PENDING_APPROVAL]')

  const isAdminUser = user?.role === 'SUPER_ADMIN' || user?.role === 'AGENCY_ADMIN'

  const handleApproveProperty = async (id: string) => {
    try {
      const authHeaders: HeadersInit = token ? { Authorization: `Bearer ${token}` } : {}
      const response = await fetch(`/api/properties/${id}/approve`, {
        method: 'POST',
        headers: authHeaders
      })
      const data = await response.json().catch(() => null)
      if (!response.ok || !data?.success) {
        alert(data?.message || 'Errore durante approvazione immobile')
        return
      }
      onRefreshData()
      alert('Immobile approvato e pubblicato con successo')
    } catch (error) {
      console.error('Errore approvazione immobile:', error)
      alert('Errore di connessione durante approvazione')
    }
  }

  const parseNum = (v: string) => {
    if (v == null) return null
    const normalized = String(v).trim()
    if (normalized === '') return null
    const n = Number(normalized)
    return Number.isFinite(n) ? n : null
  }

  const normalizeContractType = (value: unknown): 'SALE' | 'RENT' | '' => {
    const raw = String(value || '').trim().toUpperCase()
    if (!raw) return ''
    if (['SALE', 'SELL', 'VENDITA'].includes(raw)) return 'SALE'
    if (['RENT', 'LEASE', 'AFFITTO', 'LOCAZIONE'].includes(raw)) return 'RENT'
    return ''
  }

  const normalizedSearch = searchTerm.trim().toLowerCase()
  const normalizedReference = filterReference.trim().toLowerCase()

  const filteredProperties = properties.filter(property => {
    const title = (property.title || '').toLowerCase()
    const city = (property.city || '').toLowerCase()
    const address = (property.address || '').toLowerCase()
    const reference = (property.reference || '').toLowerCase()
    const province = (property.province || '').toLowerCase()
    const zipCode = String(property.zipCode || '').toLowerCase()
    const contractType = normalizeContractType(property.contractType)

    const matchesSearch =
      !normalizedSearch ||
      reference.includes(normalizedSearch) ||
      title.includes(normalizedSearch) ||
      city.includes(normalizedSearch) ||
      address.includes(normalizedSearch)

    const matchesReference = !normalizedReference || reference.includes(normalizedReference)
    const matchesType = !filterType || property.type === filterType
    const matchesContract = !filterContractType || contractType === filterContractType

    const matchesStatus = !filterStatus || (filterStatus === 'PENDING_APPROVAL'
      ? isPendingApproval(property)
      : property.status === filterStatus)

    const matchesCity = !filterCity || city.includes(filterCity.trim().toLowerCase())
    const matchesProvince = !filterProvince || province.includes(filterProvince.trim().toLowerCase())
    const matchesZipCode = !filterZipCode || zipCode.includes(filterZipCode.trim().toLowerCase())

    const matchesEnergy = !filterEnergyClass || String(property.energyClass || '').toUpperCase() === filterEnergyClass
    const matchesCondition = !filterCondition || String(property.condition || '').toUpperCase() === filterCondition

    const numericPrice = contractType === 'RENT'
      ? Number(property.rentPrice ?? property.salePrice ?? 0)
      : Number(property.salePrice ?? property.rentPrice ?? 0)

    const minPrice = parseNum(filterMinPrice)
    const maxPrice = parseNum(filterMaxPrice)
    const matchesMinPrice = minPrice == null || numericPrice >= minPrice
    const matchesMaxPrice = maxPrice == null || numericPrice <= maxPrice

    const surface = Number(property.surface ?? 0)
    const minSurface = parseNum(filterMinSurface)
    const maxSurface = parseNum(filterMaxSurface)
    const matchesMinSurface = minSurface == null || surface >= minSurface
    const matchesMaxSurface = maxSurface == null || surface <= maxSurface

    const rooms = Number(property.rooms ?? 0)
    const bedrooms = Number(property.bedrooms ?? 0)
    const bathrooms = Number(property.bathrooms ?? 0)
    const minRooms = parseNum(filterMinRooms)
    const minBedrooms = parseNum(filterMinBedrooms)
    const minBathrooms = parseNum(filterMinBathrooms)
    const matchesMinRooms = minRooms == null || rooms >= minRooms
    const matchesMinBedrooms = minBedrooms == null || bedrooms >= minBedrooms
    const matchesMinBathrooms = minBathrooms == null || bathrooms >= minBathrooms

    return (
      matchesSearch &&
      matchesReference &&
      matchesType &&
      matchesContract &&
      matchesStatus &&
      matchesCity &&
      matchesProvince &&
      matchesZipCode &&
      matchesEnergy &&
      matchesCondition &&
      matchesMinPrice &&
      matchesMaxPrice &&
      matchesMinSurface &&
      matchesMaxSurface &&
      matchesMinRooms &&
      matchesMinBedrooms &&
      matchesMinBathrooms
    )
  })


  const getStatusColor = (status: string) => {

    switch (status) {

      case 'AVAILABLE': return '#10b981'

      case 'RESERVED': return '#f59e0b'

      case 'SOLD': return '#ef4444'

      default: return '#6b7280'

