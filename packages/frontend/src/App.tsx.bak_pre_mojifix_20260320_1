                        notPublishableCount:

                          typeof data.totalNotPublishable === 'number'

                            ? data.totalNotPublishable

                            : p.notPublishableCount

                      }

                    : p

                )

              )

            })

            .catch(() => {})

        })

      } catch {

      } finally {

        if (!cancelled) {

          setPortalsLoading(false)

        }

      }

    }



    loadPortals()



    return () => {

      cancelled = true

    }

  }, [isAuthenticated, token, currentPage, logout, navigate])



  // Gestione cambio URL per pagine pubbliche

  const navigateToPublicProperty = (propertyId: string) => {

    navigate(`/public/property/${propertyId}`)

