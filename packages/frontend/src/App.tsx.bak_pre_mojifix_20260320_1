    if (tone === 'warn') return { ...base, backgroundColor: '#ffedd5', color: '#9a3412' }

    if (tone === 'error') return { ...base, backgroundColor: '#fee2e2', color: '#991b1b' }

    return { ...base, backgroundColor: '#f3f4f6', color: '#374151' }

  }



  const toMissingLabels = (requirements: PortalRequirement[]) => {

    const out: string[] = []

    for (const req of requirements) {

      if (req === 'price' && !hasPrice) out.push('prezzo')

      if (req === 'image' && !hasImage) out.push('immagine')

      if (req === 'giComuneIstat' && !hasGiComuneIstat) out.push('giComuneIstat')

