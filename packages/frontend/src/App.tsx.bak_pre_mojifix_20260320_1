  >([])

  const [globalPortalsLoading, setGlobalPortalsLoading] = useState(false)

  const [globalPortalsError, setGlobalPortalsError] = useState<string | null>(null)

  const [selectedGlobalPortalId, setSelectedGlobalPortalId] = useState<string | null>(null)

  const [globalPortalForm, setGlobalPortalForm] = useState<{

    username: string

    password: string

    apiKey: string

    endpoint: string

  }>({

    username: '',

    password: '',

    apiKey: '',

    endpoint: '',

  })

  const [globalPortalSaving, setGlobalPortalSaving] = useState(false)

  const [globalPortalSaveMessage, setGlobalPortalSaveMessage] = useState<string | null>(null)

  const [globalPortalTesting, setGlobalPortalTesting] = useState(false)

  const [globalPortalTestMessage, setGlobalPortalTestMessage] = useState<string | null>(null)

  const [portalRequests, setPortalRequests] = useState<

    {

      id: string

      portalId: string

      status: string

      notes: string | null

      agency: {

        id: string

        name: string

        slug: string | null

        status: string

      }

      assignedTo: {

        id: string

        email: string

        firstName: string | null

        lastName: string | null

      } | null

      createdAt: string

      updatedAt: string

    }[]

  >([])

  const [portalRequestsLoading, setPortalRequestsLoading] = useState(false)

  const [portalRequestsError, setPortalRequestsError] = useState<string | null>(null)

  const [portalRequestsPage, setPortalRequestsPage] = useState(1)

  const [portalRequestsTotalPages, setPortalRequestsTotalPages] = useState(1)

  const [portalRequestsPortalFilter, setPortalRequestsPortalFilter] = useState('')

  const [portalRequestsStatusFilter, setPortalRequestsStatusFilter] = useState('')

  const [portalRequestsAgencyFilter, setPortalRequestsAgencyFilter] = useState('')

  const [selectedPortalRequestId, setSelectedPortalRequestId] = useState<string | null>(null)

  const [selectedPortalRequestSaving, setSelectedPortalRequestSaving] = useState(false)

  const [selectedPortalRequestStatus, setSelectedPortalRequestStatus] = useState('')

  const [selectedPortalRequestAssignedToId, setSelectedPortalRequestAssignedToId] = useState('')

  const [selectedPortalRequestNotes, setSelectedPortalRequestNotes] = useState('')

  const [notificationHover, setNotificationHover] = useState(false)

  const [auditLogs, setAuditLogs] = useState<any[]>([])

  const [auditLogsLoading, setAuditLogsLoading] = useState(false)

  const [auditLogsError, setAuditLogsError] = useState<string | null>(null)

  const [auditLogsPage, setAuditLogsPage] = useState(1)

  const [auditLogsTotalPages, setAuditLogsTotalPages] = useState(1)

  const [auditActionFilter, setAuditActionFilter] = useState('')

  const [auditEntityFilter, setAuditEntityFilter] = useState('')

  const [auditEntityIdFilter, setAuditEntityIdFilter] = useState('')

  const [auditUserIdFilter, setAuditUserIdFilter] = useState('')

  const [auditFromFilter, setAuditFromFilter] = useState('')

  const [auditToFilter, setAuditToFilter] = useState('')

  const [selectedAuditLogId, setSelectedAuditLogId] = useState<string | null>(null)

  const [selectedAuditLog, setSelectedAuditLog] = useState<any | null>(null)



  const shellBackground = '#020617'

  const shellGradientBackground = 'radial-gradient(circle at top, #1e293b 0, #020617 55%)'

  const cardBackground = 'rgba(15, 23, 42, 0.9)'

  const cardBorder = '1px solid rgba(148, 163, 184, 0.35)'



  const getInternalToken = () => {

    if (typeof window === 'undefined') return null

    return window.localStorage.getItem('internal_token')

  }



  const internalFetch = async (input: RequestInfo | URL, init: RequestInit = {}) => {

    const token = getInternalToken()

    const baseHeaders: Record<string, string> = {}

    if (init.headers instanceof Headers) {

      init.headers.forEach((value, key) => {

        baseHeaders[key] = value

      })

    } else if (Array.isArray(init.headers)) {

      init.headers.forEach(([key, value]) => {

        baseHeaders[key] = value as string

      })

    } else if (init.headers) {

      Object.assign(baseHeaders, init.headers as Record<string, string>)

    }



    const headers =

      token != null && token !== ''

        ? {

            ...baseHeaders,

            Authorization: `Bearer ${token}`

          }

        : baseHeaders



    const response = await fetch(input, { ...init, headers })

    return response

  }



  const loadAuditLogs = async (page?: number) => {

    setAuditLogsLoading(true)

    setAuditLogsError(null)

    try {

      const params = new URLSearchParams()

      if (auditActionFilter.trim() !== '') {

        params.set('action', auditActionFilter.trim())

      }

      if (auditEntityFilter.trim() !== '') {

        params.set('entity', auditEntityFilter.trim())

      }

      if (auditEntityIdFilter.trim() !== '') {

        params.set('entityId', auditEntityIdFilter.trim())

      }

      if (auditUserIdFilter.trim() !== '') {

        params.set('userId', auditUserIdFilter.trim())

      }

      if (auditFromFilter.trim() !== '') {

        params.set('from', auditFromFilter.trim())

      }

      if (auditToFilter.trim() !== '') {

        params.set('to', auditToFilter.trim())

      }

      const effectivePage = page && page > 0 ? page : auditLogsPage

      params.set('page', String(effectivePage))

      params.set('limit', '50')

      const queryString = params.toString()

      const response = await internalFetch(`/internal/audit-logs${queryString ? `?${queryString}` : ''}`)

      const data = await response.json().catch(() => null)

      if (

        !response.ok ||

        !data?.success ||

        !data.data ||

        !Array.isArray(data.data.items) ||

        !data.data.pagination

      ) {

        setAuditLogsError(data?.message || 'Errore nel caricamento degli audit log')

        return

      }

      setAuditLogs(data.data.items)

      setAuditLogsPage(Number(data.data.pagination.page) || 1)

      setAuditLogsTotalPages(Number(data.data.pagination.pages) || 1)

      if (data.data.items.length > 0) {

        const first = data.data.items[0]

        setSelectedAuditLogId(String(first.id))

        setSelectedAuditLog(first)

      } else {

        setSelectedAuditLogId(null)

        setSelectedAuditLog(null)

      }

    } catch {

      setAuditLogsError('Errore nel caricamento degli audit log')

    } finally {

      setAuditLogsLoading(false)

    }

  }



  const loadPortalRequests = async (page?: number) => {

    setPortalRequestsLoading(true)

    setPortalRequestsError(null)

    try {

      const params = new URLSearchParams()

      if (portalRequestsPortalFilter.trim() !== '') {

        params.set('portalId', portalRequestsPortalFilter.trim())

      }

      if (portalRequestsStatusFilter.trim() !== '') {

        params.set('status', portalRequestsStatusFilter.trim())

      }

      if (portalRequestsAgencyFilter.trim() !== '') {

        params.set('agencyId', portalRequestsAgencyFilter.trim())

      }

      const effectivePage = page && page > 0 ? page : portalRequestsPage

      params.set('page', String(effectivePage))

      params.set('limit', '25')

      const queryString = params.toString()

      const response = await internalFetch(`/internal/portal-activation-requests${queryString ? `?${queryString}` : ''}`)

      const data = await response.json().catch(() => null)

      if (

        !response.ok ||

        !data?.success ||

        !data.data ||

        !Array.isArray(data.data.items) ||

        !data.data.pagination

      ) {

        setPortalRequestsError(data?.message || 'Errore nel caricamento delle richieste portali')

        return

      }

      setPortalRequests(

        data.data.items.map((r: any) => ({

          id: String(r.id),

          portalId: String(r.portalId),

          status: String(r.status),

          notes: r.notes != null ? String(r.notes) : null,

          agency: {

            id: String(r.agency.id),

            name: String(r.agency.name),

            slug: r.agency.slug != null ? String(r.agency.slug) : null,

            status: String(r.agency.status)

          },

          assignedTo: r.assignedTo

            ? {

                id: String(r.assignedTo.id),

                email: String(r.assignedTo.email),

                firstName: r.assignedTo.firstName != null ? String(r.assignedTo.firstName) : null,

                lastName: r.assignedTo.lastName != null ? String(r.assignedTo.lastName) : null

              }

            : null,

          createdAt: String(r.createdAt),

          updatedAt: String(r.updatedAt)

        }))

      )

      setPortalRequestsPage(Number(data.data.pagination.page) || 1)

      setPortalRequestsTotalPages(Number(data.data.pagination.pages) || 1)

      if (data.data.items.length > 0) {

        const first = data.data.items[0]

        setSelectedPortalRequestId(String(first.id))

        setSelectedPortalRequestStatus(String(first.status))

        setSelectedPortalRequestAssignedToId(first.assignedToId ? String(first.assignedToId) : '')

        setSelectedPortalRequestNotes(first.notes != null ? String(first.notes) : '')

      } else {

        setSelectedPortalRequestId(null)

      }

    } catch {

      setPortalRequestsError('Errore nel caricamento delle richieste portali')

    } finally {

      setPortalRequestsLoading(false)

    }

  }



  const saveSelectedPortalRequest = async () => {

    if (!selectedPortalRequestId) return

    setSelectedPortalRequestSaving(true)

    setPortalRequestsError(null)

    try {

      const payload: any = {

        status: selectedPortalRequestStatus.trim() !== '' ? selectedPortalRequestStatus.trim() : undefined,

        notes: selectedPortalRequestNotes,

        assignedToId:

          selectedPortalRequestAssignedToId.trim() !== ''

            ? selectedPortalRequestAssignedToId.trim()

            : null

      }

      const response = await internalFetch(

        `/internal/portal-activation-requests/${encodeURIComponent(selectedPortalRequestId)}`,

        {

          method: 'PATCH',

          headers: { 'Content-Type': 'application/json' },

          body: JSON.stringify(payload)

        }

      )

      const data = await response.json().catch(() => null)

      if (!response.ok || !data?.success) {

        setPortalRequestsError(data?.message || 'Errore durante il salvataggio della richiesta')

        return

      }

      loadPortalRequests(portalRequestsPage)

    } catch {

      setPortalRequestsError('Errore durante il salvataggio della richiesta')

    } finally {

      setSelectedPortalRequestSaving(false)

    }

  }



  const loadAgencies = async (status?: string) => {

    try {

      const params = new URLSearchParams()

      if (status && status !== '') params.set('status', status)

      const response = await internalFetch(`/internal/agencies${params.toString() ? `?${params.toString()}` : ''}`)

      const data = await response.json().catch(() => null)

      if (!response.ok || !data?.success || !Array.isArray(data.data)) {

        setError(data?.message || 'Errore nel caricamento agenzie')

        return

      }

      setAgencies(

        data.data.map((a: any) => ({

          id: String(a.id),

          name: String(a.name),

          slug: a.slug != null ? String(a.slug) : null,

          status: String(a.status),

          onboardingStatus: a.onboardingStatus ? String(a.onboardingStatus) : 'PENDING',

          createdAt: a.createdAt,

          currentPlanCode: a.currentPlanCode != null ? String(a.currentPlanCode) : null,

          instance: a.instance

            ? {

                id: String(a.instance.id),

                status: String(a.instance.status),

                slug: String(a.instance.slug),

                baseUrl: a.instance.baseUrl != null ? String(a.instance.baseUrl) : null

              }

            : null

        }))

      )

    } catch {

      setError('Errore nel caricamento agenzie')

    }

  }



  const loadAgencyDetail = async (id: string) => {

    setDetailLoading(true)

    setDetailError(null)

    try {

      const response = await internalFetch(`/internal/agencies/${encodeURIComponent(id)}`)

      const data = await response.json().catch(() => null)

      if (!response.ok || !data?.success || !data.data) {

        setDetailError(data?.message || 'Errore nel caricamento agenzia')

        return

      }

      setSelectedAgencyDetail(data.data)

      setAgencyDetailTab('overview')

    } catch {

      setDetailError('Errore nel caricamento agenzia')

    } finally {

      setDetailLoading(false)

    }

  }



  const loadGlobalPortals = async () => {

    setGlobalPortalsLoading(true)

    setGlobalPortalsError(null)

    setGlobalPortalSaveMessage(null)

    setGlobalPortalTestMessage(null)

    try {

      const response = await internalFetch('/internal/global-portals')

      const data = await response.json().catch(() => null)

      if (!response.ok || !data?.success || !data.data || !Array.isArray(data.data.portals)) {

        setGlobalPortalsError(data?.message || 'Errore nel caricamento dei portali globali')

        return

      }

      setGlobalPortals(

        data.data.portals.map((p: any) => ({

          id: String(p.id),

          label: String(p.label),

          kind: String(p.kind),

          modeLabel: String(p.modeLabel),

          implemented: !!p.implemented,

          feedPath: p.feedPath != null ? String(p.feedPath) : null,

          requirements: Array.isArray(p.requirements) ? p.requirements.map((r: any) => String(r)) : [],

          credentials: {

            username: p.credentials?.username != null ? String(p.credentials.username) : null,

            endpoint: p.credentials?.endpoint != null ? String(p.credentials.endpoint) : null,

            hasPassword: !!p.credentials?.hasPassword,

            hasApiKey: !!p.credentials?.hasApiKey,

          },

        })),

      )

      if (!selectedGlobalPortalId && data.data.portals.length > 0) {

        const first = data.data.portals[0]

        setSelectedGlobalPortalId(String(first.id))

        setGlobalPortalForm({

          username: first.credentials?.username != null ? String(first.credentials.username) : '',

          password: '',

          apiKey: '',

          endpoint: first.credentials?.endpoint != null ? String(first.credentials.endpoint) : '',

        })

      } else if (selectedGlobalPortalId) {

        const current = data.data.portals.find((p: any) => String(p.id) === selectedGlobalPortalId)

        if (current) {

          setGlobalPortalForm({

            username: current.credentials?.username != null ? String(current.credentials.username) : '',

            password: '',

            apiKey: '',

            endpoint: current.credentials?.endpoint != null ? String(current.credentials.endpoint) : '',

          })

        }

      }

    } catch {

      setGlobalPortalsError('Errore nel caricamento dei portali globali')

    } finally {

      setGlobalPortalsLoading(false)

    }

  }



  useEffect(() => {

    if (typeof window === 'undefined') return

    const storedToken = window.localStorage.getItem('internal_token')

    const storedRole = window.localStorage.getItem('internal_role')

    if (storedToken) {

      setLoggedIn(true)

      loadAgencies()

    }

    if (storedRole) {

      setInternalRole(storedRole)

    }

  }, [])



  useEffect(() => {

    if (!selectedAgencyDetail || !selectedAgencyDetail.subscriptions || selectedAgencyDetail.subscriptions.length === 0) {

      setSubscriptionEdit(null)

      return

    }

    const s = selectedAgencyDetail.subscriptions[0]

    setSubscriptionEdit({

      planCode: s.planCode || '',

      status: s.status || '',

      currentPeriodEnd: s.currentPeriodEnd ? String(s.currentPeriodEnd).slice(0, 10) : '',

      stripeCustomerId: s.stripeCustomerId || '',

      stripeSubscriptionId: s.stripeSubscriptionId || ''

    })

    setSubscriptionError(null)

    setSubscriptionSuccess(null)

  }, [selectedAgencyDetail])



  const handleLogout = () => {

    if (typeof window !== 'undefined') {

      window.localStorage.removeItem('internal_token')

      window.localStorage.removeItem('internal_role')

    }

    setLoggedIn(false)

    setStep(1)

    setMfaToken(null)

    setCode('')

    setPassword('')

    setEmail('')

    setAgencies([])

    setSelectedAgencyId(null)

    setSelectedAgencyDetail(null)

    setInternalRole(null)

    setAgencyDetailTab('overview')

    setSubscriptionEdit(null)

    setSubscriptionError(null)

    setSubscriptionSuccess(null)

  }



  const handleLogin = async (e: React.FormEvent) => {

    e.preventDefault()

    setError(null)

    setLoading(true)



    try {

      const response = await fetch('/internal/auth/login', {

        method: 'POST',

        headers: { 'Content-Type': 'application/json' },

        body: JSON.stringify({ email, password })

      })



      const data = await response.json().catch(() => null)



      if (!response.ok || !data?.success) {

        setError(data?.message || 'Credenziali non valide')

        return

      }



      if (data?.data?.token) {

        if (typeof window !== 'undefined') {

          window.localStorage.setItem('internal_token', String(data.data.token))

          if (data.data.user && data.data.user.role) {

            window.localStorage.setItem('internal_role', String(data.data.user.role))

            setInternalRole(String(data.data.user.role))

          }

        }

        setLoggedIn(true)

        loadAgencies()

        return

      }



      if (data?.data?.mfaToken) {

        setMfaToken(String(data.data.mfaToken))

        setStep(2)

        return

      }



      setError(data?.message || 'Credenziali non valide')

    } catch {

      setError('Errore durante il login')

    } finally {

      setLoading(false)

    }

  }



  const handleVerifyMfa = async (e: React.FormEvent) => {

    e.preventDefault()

    if (!mfaToken) return



    setError(null)

    setLoading(true)



    try {

      const response = await fetch('/internal/auth/mfa/verify', {

        method: 'POST',

        headers: { 'Content-Type': 'application/json' },

        body: JSON.stringify({ mfaToken, code })

      })



      const data = await response.json().catch(() => null)



      if (!response.ok || !data?.success || !data?.data?.token) {

        setError(data?.message || 'Codice MFA non valido')

        return

      }



      if (typeof window !== 'undefined') {

        window.localStorage.setItem('internal_token', String(data.data.token))

        if (data.data.user && data.data.user.role) {

          window.localStorage.setItem('internal_role', String(data.data.user.role))

          setInternalRole(String(data.data.user.role))

        }

      }

      setLoggedIn(true)

      loadAgencies()

    } catch {

      setError('Errore durante la verifica MFA')

    } finally {

      setLoading(false)

    }

  }



  if (!loggedIn) {

    return (

      <div style={{ minHeight: '100vh', display: 'flex', backgroundColor: shellBackground, color: 'white' }}>

        <div style={{ flex: 1, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>

          <div style={{ width: '100%', maxWidth: '420px', backgroundColor: 'white', borderRadius: '0.75rem', padding: '2rem', boxShadow: '0 25px 50px -12px rgba(15,23,42,0.5)' }}>

            <div style={{ marginBottom: '1.5rem' }}>

              <h1 style={{ fontSize: '1.5rem', fontWeight: 600, marginBottom: '0.25rem', color: '#0f172a' }}>Super-dashboard</h1>

              <p style={{ fontSize: '0.875rem', color: '#6b7280' }}>Accesso riservato allo staff interno</p>

            </div>



            <>

              {error && (

                <div style={{ marginBottom: '1rem', padding: '0.75rem 1rem', borderRadius: '0.5rem', backgroundColor: '#fef2f2', color: '#b91c1c', fontSize: '0.875rem' }}>

                  {error}

                </div>

              )}



              {step === 1 && (

                <form onSubmit={handleLogin} style={{ display: 'flex', flexDirection: 'column', gap: '1rem' }}>

                  <div>

                    <label htmlFor="internal-email" style={{ display: 'block', fontSize: '0.875rem', fontWeight: 500, marginBottom: '0.25rem' }}>

                      Email

                    </label>

                    <input

                      id="internal-email"

                      type="email"

                      value={email}

                      onChange={e => setEmail(e.target.value)}

                      required

                      style={{

                        width: '100%',

                        padding: '0.5rem 0.75rem',

                        borderRadius: '0.5rem',

                        border: '1px solid #d1d5db',

                        fontSize: '0.875rem'

                      }}

                    />

                  </div>



                  <div>

                    <label htmlFor="internal-password" style={{ display: 'block', fontSize: '0.875rem', fontWeight: 500, marginBottom: '0.25rem' }}>

                      Password

                    </label>

                    <input

                      id="internal-password"

                      type="password"

                      value={password}

                      onChange={e => setPassword(e.target.value)}

                      required

                      style={{

                        width: '100%',

                        padding: '0.5rem 0.75rem',

                        borderRadius: '0.5rem',

                        border: '1px solid #d1d5db',

                        fontSize: '0.875rem'

                      }}

                    />

                  </div>



                  <button

                    type="submit"

                    disabled={loading}

                    style={{

                      marginTop: '0.5rem',

                      width: '100%',

                      padding: '0.75rem 1rem',

