        feedUrl: null

      }

    }



    return {

      id: portal.id,

      label: portal.label,

      mode: portal.modeLabel,

      status: { tone: 'neutral' as const, label: enabled ? 'SELEZIONATO' : 'NON SELEZIONATO', details: '' },

      feedUrl: null

