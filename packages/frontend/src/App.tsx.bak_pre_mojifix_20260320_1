  const [onboardingPortalsChoices, setOnboardingPortalsChoices] = useState<string[]>([])



  const { user, token, refreshToken, isAuthenticated, logout, setTokens } = useAuthStore()

  const userRole = user?.role ?? null

  const mustChangePassword = user?.mustChangePassword ?? false



  const mergeHeaders = (headers?: HeadersInit) => {

    const result: Record<string, string> = {}

    if (!headers) return result

    if (headers instanceof Headers) {

      headers.forEach((value, key) => {

        result[key] = value

      })

      return result

    }

    if (Array.isArray(headers)) {

      headers.forEach(([key, value]) => {

        result[key] = value

      })

      return result

    }

    return { ...(headers as Record<string, string>) }

  }



  const tryRefresh = async () => {

    if (!refreshToken) return null

    try {

      const response = await globalThis.fetch('/api/auth/refresh', {

        method: 'POST',

        headers: { 'Content-Type': 'application/json' },

        body: JSON.stringify({ refreshToken }),

        credentials: 'include',

      })

      const payload = await response.json().catch(() => null)

      if (!response.ok || !payload?.success) return null

      const nextToken = payload?.data?.token

      const nextRefreshToken = payload?.data?.refreshToken

      if (!nextToken) return null

      setTokens(String(nextToken), nextRefreshToken != null ? String(nextRefreshToken) : undefined)

      return { token: String(nextToken) }

    } catch {

      return null

    }

  }



  const fetch = async (

    input: RequestInfo | URL,

    init: RequestInit = {},

    hasRetried = false

  ) => {

    const url =

      typeof input === 'string'

        ? input

        : input instanceof Request

          ? input.url

          : String(input)

    const shouldAuth = url.startsWith('/api')

    const baseHeaders = mergeHeaders(init.headers)

    const headers = shouldAuth && token ? { ...baseHeaders, Authorization: `Bearer ${token}` } : baseHeaders



    const response = await globalThis.fetch(input, { ...init, headers, credentials: 'include' })

    if (response.status === 401) {

      const canAttemptRefresh =

        shouldAuth && !hasRetried && url !== '/api/auth/refresh' && url !== '/api/auth/login'



      if (canAttemptRefresh) {

        const refreshed = await tryRefresh()

        if (refreshed && typeof input === 'string') {

          const retryHeaders = token

            ? { ...baseHeaders, Authorization: `Bearer ${refreshed.token}` }

            : { ...baseHeaders, Authorization: `Bearer ${refreshed.token}` }

          const retryResponse = await globalThis.fetch(input, {

            ...init,

            headers: retryHeaders,

            credentials: 'include',

          })

          if (retryResponse.status !== 401) return retryResponse

        }

      }



      logout()

      navigate('/login')

    }

    return response

  }



  const loadOnboardingStatus = async () => {

    if (!isAuthenticated || !token) return null

    setOnboardingLoading(true)

    setOnboardingError(null)

    try {

      const response = await fetch('/api/onboarding/status', {

        method: 'GET',

        headers: { 'Content-Type': 'application/json' }

      })

      const payload = await response.json().catch(() => null)

      if (!response.ok || !payload?.success || !payload?.data) {

        setOnboardingError(payload?.message || 'Errore nel caricamento dello stato di onboarding')

        return null

      }

      const data = payload.data

      const status: string = data.status

      const step: number = data.step

      setOnboardingStep(step || 1)

      setOnboardingChecklist({

        agencyDataComplete: Boolean(data.agencyDataComplete),

        teamComplete: Boolean(data.teamComplete),

        configComplete: Boolean(data.configComplete),

        missingAgencyFields: Array.isArray(data.missingAgencyFields) ? data.missingAgencyFields : [],

        missingTeam: Array.isArray(data.missingTeam) ? data.missingTeam : [],

        missingConfig: Array.isArray(data.missingConfig) ? data.missingConfig : []

      })

      if (status !== 'COMPLETED') {

        if (location.pathname !== '/onboarding') {

          navigate('/onboarding', { replace: true })

          setCurrentPage('onboarding')

        }

      } else {

        if (location.pathname === '/onboarding') {

          navigate('/dashboard', { replace: true })

          setCurrentPage('dashboard')

        }

      }

      return data

    } catch (error) {

      setOnboardingError('Errore nel caricamento dello stato di onboarding')

      return null

    } finally {

      setOnboardingChecked(true)

      setOnboardingLoading(false)

    }

  }



  const loadOnboardingConfig = async () => {

