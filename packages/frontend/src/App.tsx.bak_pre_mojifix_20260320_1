        try {

          const docs = await onLoadDocuments(contact.id)

          const missingCount = requiredDocumentTypes.filter(type => !docs.some(doc => doc.type === type)).length

          setDocumentStats(prev => {

            if (prev[contact.id]) {

              return prev

            }

            return {

              ...prev,

              [contact.id]: { missingCount }

            }

