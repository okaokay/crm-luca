    try {

      const authHeaders: HeadersInit = token ? { Authorization: `Bearer ${token}` } : {}

      const response = await fetch(

        `/api/contacts/${encodeURIComponent(contact.id)}/documents/${encodeURIComponent(document.id)}`,

        { headers: authHeaders }

      )

      if (!response.ok) {

        alert('Errore nel caricamento del documento')

        return

      }

      const blob = await response.blob()

      const url = URL.createObjectURL(blob)

      window.open(url, '_blank')

      window.setTimeout(() => {

        URL.revokeObjectURL(url)

      }, 60000)

    } catch (error) {

      console.error('Errore visualizzazione documento:', error)

      alert('Errore di connessione durante la visualizzazione del documento')

    }

  }



