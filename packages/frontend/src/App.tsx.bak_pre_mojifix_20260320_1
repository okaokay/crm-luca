function PropertyPortalsTab({

  property,

  onReload,

  onRefreshData

}: {

  property: Property

  onReload: () => Promise<void>

  onRefreshData: () => void

}) {

  const [portalRegistry, setPortalRegistry] = useState<PortalRegistryItem[]>([])

  const [workingAction, setWorkingAction] = useState<string | null>(null)

  const { token, logout } = useAuthStore()

  const navigate = useNavigate()



  useEffect(() => {

    const fetchRegistry = async () => {

      try {

        const headers: HeadersInit = token ? { Authorization: `Bearer ${token}` } : {}

        const response = await fetch('/api/portals', { headers })



        if (response.status === 401) {

          logout()

          navigate('/login')

          return

        }



        const data = await response.json().catch(() => null)

        if (!data?.success) return

        const nextPortals = Array.isArray(data?.data?.portals) ? (data.data.portals as PortalRegistryItem[]) : []

        setPortalRegistry(nextPortals)

      } catch {}

    }

    fetchRegistry()

  }, [token, logout, navigate])



  const portalTargets = Array.isArray(property.portalTargets) ? property.portalTargets : []

  const hasImage = Array.isArray(property.images) && property.images.some((u) => typeof u === 'string' && u.trim())

  const salePrice = property.salePrice != null ? Number(property.salePrice) : null

  const rentPrice = property.rentPrice != null ? Number(property.rentPrice) : null

  const chosenPrice = property.contractType === 'RENT' ? rentPrice : salePrice

  const hasPrice = chosenPrice != null && Number.isFinite(chosenPrice) && chosenPrice > 0

  const giComuneIstat = property.giComuneIstat != null ? String(property.giComuneIstat).trim() : ''

  const hasGiComuneIstat = Boolean(giComuneIstat)

  const hasGiListingId = property.giListingId != null && Number.isFinite(Number(property.giListingId)) && Number(property.giListingId) > 0

  const latitude = property.latitude != null ? Number(property.latitude) : null

  const longitude = property.longitude != null ? Number(property.longitude) : null

  const hasLocation = (latitude != null && Number.isFinite(latitude) && longitude != null && Number.isFinite(longitude)) || /^\d{6}$/.test(giComuneIstat)



