        }))

        setPortals(mapped)



        mapped.forEach((portal) => {

          fetch(`/api/portals/${encodeURIComponent(portal.id)}/stats`, { headers })

            .then((res) => {

              if (res.status === 401) {

                logout()

                navigate('/login')

                return null

              }

              return res.json().catch(() => null)

            })

            .then((statsPayload) => {

              if (!statsPayload?.success || !statsPayload.data || cancelled) return

              const data = statsPayload.data

              setPortals((prev) =>

                prev.map((p) =>

                  p.id === portal.id

                    ? {

                        ...p,

                        selectedCount:

                          typeof data.totalSelected === 'number' ? data.totalSelected : p.selectedCount,

                        publishedCount:

                          typeof data.totalPublished === 'number' ? data.totalPublished : p.publishedCount,

