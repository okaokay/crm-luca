    if (!enabled) return { tone: 'neutral' as const, label: 'NON SELEZIONATO', details: '' }

    if (missing.length === 0) {

      if (portalId === 'FACEBOOK_MARKETPLACE') return { tone: 'ok' as const, label: 'INCLUSO NEL CATALOGO', details: '' }

      return { tone: 'ok' as const, label: 'INCLUSO NEL FEED', details: '' }

