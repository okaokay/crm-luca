function ContactModal({

  contact,

  category,

  onSave,

  onCancel,

  agents,

  onLoadDocuments,

  onUploadDocument,

  onDeleteDocument,

  canManageAssignments

}: {

  contact: Contact | null

  category: 'CLIENT' | 'PROPRIETOR'

  onSave: (contact: Omit<Contact, 'id' | 'createdAt'>) => void

  onCancel: () => void

  agents: Agent[]

  onLoadDocuments: (contactId: string) => Promise<OwnerDocument[]>

  onUploadDocument: (

    contactId: string,

    payload: { file: File; type: string; side?: string }

  ) => Promise<OwnerDocument | null>

  onDeleteDocument: (contactId: string, documentId: string) => Promise<boolean>

  canManageAssignments: boolean

}) {

  const [formData, setFormData] = useState({

    firstName: contact?.firstName || '',

    lastName: contact?.lastName || '',

    email: contact?.email || '',

    phone: contact?.phone || '',

    type: contact?.type || (category === 'CLIENT' ? 'BUYER' : 'SELLER'),

    category: contact?.category || category,

    city: contact?.city || '',

    province: contact?.province || '',

    address: contact?.address || '',

    zipCode: contact?.zipCode || '',

    birthDate: contact?.birthDate ? contact.birthDate.slice(0, 10) : '',

    birthPlace: contact?.birthPlace || '',

    fiscalCode: contact?.fiscalCode || '',

    budget: contact?.budget || undefined,

    preferences: contact?.preferences || '',

    requestApartmentType: contact?.requestApartmentType || '',

    requestBedrooms: contact?.requestBedrooms || undefined,

    requestBathrooms: contact?.requestBathrooms || undefined,

    requestFloor: contact?.requestFloor || undefined,

    assignedAgent: contact?.assignedAgent || '',

    source: contact?.source || '',

    notes: contact?.notes || '',

    tags: contact?.tags || [],

    isActive: contact?.isActive ?? true

  })



  const [citySuggestions, setCitySuggestions] = useState<ItalianCity[]>([])

  const [showCitySuggestions, setShowCitySuggestions] = useState(false)

  const [provinceOptions, setProvinceOptions] = useState<ItalianProvince[]>([])



  const [documents, setDocuments] = useState<OwnerDocument[]>([])

  const [documentsLoading, setDocumentsLoading] = useState(false)

  const [documentsError, setDocumentsError] = useState<string | null>(null)

  const [activeClientTab, setActiveClientTab] = useState<'profile' | 'request'>('profile')

  const [newDocumentType, setNewDocumentType] = useState('')

  const [newDocumentSide, setNewDocumentSide] = useState('')

  const [newDocumentFile, setNewDocumentFile] = useState<File | null>(null)

  const [uploadingDocument, setUploadingDocument] = useState(false)

  const { token } = useAuthStore()



  useEffect(() => {

    const previousOverflow = document.body.style.overflow

    document.body.style.overflow = 'hidden'

    return () => {

      document.body.style.overflow = previousOverflow

    }

  }, [])



  useEffect(() => {

    loadItalianProvinces()

      .then(setProvinceOptions)

      .catch(() => {

        setProvinceOptions([])

      })

  }, [])



  useEffect(() => {

    if (category !== 'PROPRIETOR' || !contact || !contact.id) {

      setDocuments([])

