function PublicCheckoutPage() {

  const location = useLocation()

  const [selectedPlan, setSelectedPlan] = useState<'BASE' | 'PRO' | 'ENTERPRISE'>('BASE')

  const [agencyName, setAgencyName] = useState('')

  const [adminEmail, setAdminEmail] = useState('')

  const [loading, setLoading] = useState(false)

  const [error, setError] = useState<string | null>(null)

  type CheckoutStatus = 'PENDING' | 'PROVISIONING' | 'READY' | 'ERROR'

  const [checkoutStatus, setCheckoutStatus] = useState<CheckoutStatus | null>(null)

  const [checkoutMessage, setCheckoutMessage] = useState<string | null>(null)

  const [checkoutError, setCheckoutError] = useState<string | null>(null)



  const path = location.pathname

  let mode: 'form' | 'success' | 'cancel' = 'form'

  if (path.startsWith('/public/checkout/success')) {

    mode = 'success'

  } else if (path.startsWith('/public/checkout/cancel')) {

    mode = 'cancel'

  }



  useEffect(() => {

    if (mode !== 'success') return



    const params = new URLSearchParams(location.search || '')

    const sessionId = params.get('session_id')



    if (!sessionId) {

      setCheckoutStatus('ERROR')

      setCheckoutMessage(

        "Parametro session_id mancante nell'URL. Contatta il supporto per completare l'attivazione."

      )

      setCheckoutError("Parametro session_id mancante nell'URL.")

      return

    }



    let cancelled = false

    const pollIntervalMs = 7000

    const maxDurationMs = 15 * 60 * 1000

    const startedAt = Date.now()



    const checkStatus = async () => {

      if (cancelled) return

      try {

        const response = await fetch(

          `/api/public/checkout/status?session_id=${encodeURIComponent(sessionId)}`

        )

        const data = await response.json().catch(() => null)



        if (!response.ok || !data?.success || !data?.data) {

          if (!cancelled) {

            setCheckoutError('Errore nel controllo dello stato. Riproviamo tra poco...')

          }

          return

        }



        const rawStatus = typeof data.data.status === 'string' ? data.data.status.toUpperCase() : ''

        let normalizedStatus: CheckoutStatus | null = null

        if (

          rawStatus === 'PENDING' ||

          rawStatus === 'PROVISIONING' ||

          rawStatus === 'READY' ||

          rawStatus === 'ERROR'

        ) {

          normalizedStatus = rawStatus as CheckoutStatus

        }



        const nextMessage: string | null =

          data.data.message != null ? String(data.data.message) : null

        const nextBaseUrl: string | null =

          data.data.baseUrl != null && String(data.data.baseUrl).trim() !== ''

            ? String(data.data.baseUrl)

            : null



        if (cancelled || !normalizedStatus) {

          return

        }



        if (normalizedStatus === 'READY' && nextBaseUrl) {

          setCheckoutStatus('READY')

          setCheckoutMessage(

            nextMessage || 'La tua istanza Ò¨ pronta. Reindirizzamento in corso...'

          )

          setCheckoutError(null)

          window.location.href = nextBaseUrl

          return

        }



        if (normalizedStatus === 'ERROR') {

          setCheckoutStatus('ERROR')

          setCheckoutMessage(

            nextMessage || 'Si Ò¨ verificato un errore durante il provisioning della tua istanza.'

          )

          setCheckoutError(null)

          return

        }



        if (normalizedStatus === 'PROVISIONING' || normalizedStatus === 'PENDING') {

          setCheckoutStatus(normalizedStatus)

          if (normalizedStatus === 'PROVISIONING') {

            setCheckoutMessage(

              nextMessage ||

                'Stiamo configurando la tua istanza. Questa operazione puÒ² richiedere alcuni minuti.'

            )

          } else {

            setCheckoutMessage(

              nextMessage ||

                'Stiamo preparando la tua agenzia. Questa operazione puÒ² richiedere alcuni minuti.'

            )

          }

          setCheckoutError(null)

        }

      } catch {

        if (!cancelled) {

          setCheckoutError('Errore di rete nel controllo dello stato. Riproviamo tra poco...')

        }

      }

    }



    void checkStatus()



    const intervalId = window.setInterval(() => {

      if (cancelled) return

      const elapsed = Date.now() - startedAt

      if (elapsed >= maxDurationMs) {

        cancelled = true

        window.clearInterval(intervalId)

        setCheckoutStatus('ERROR')

        setCheckoutMessage(

          'Il provisioning sta impiegando piÒ¹ tempo del previsto. Contatta il supporto per verificare lo stato della tua istanza.'

        )

        setCheckoutError(null)

        return

      }

      void checkStatus()

    }, pollIntervalMs)



    return () => {

      cancelled = true

      window.clearInterval(intervalId)

    }

  }, [mode, location.search])



  const plans: { code: 'BASE' | 'PRO' | 'ENTERPRISE'; name: string; price: string; description: string; features: string[] }[] = [

    {

      code: 'BASE',

      name: 'Base',

      price: 'âa¬39/mese',

      description: 'Per piccole agenzie che iniziano a digitalizzare il flusso',

      features: ['Fino a 2 utenti', 'Gestione immobili e clienti', 'Agenda appuntamenti']

    },

    {

      code: 'PRO',

      name: 'Pro',

      price: 'âa¬69/mese',

      description: 'Per agenzie strutturate che vogliono crescere',

      features: ['Utenti illimitati', 'Portali immobiliari integrati', 'Report avanzati']

    },

    {

      code: 'ENTERPRISE',

      name: 'Enterprise',

      price: 'Su misura',

      description: 'Per network e franchising con esigenze avanzate',

      features: ['Setup personalizzato', 'Formazione dedicata', 'Supporto prioritario']

    }

  ]



  const handleSubmit = async (e: React.FormEvent) => {

    e.preventDefault()

    setError(null)



    const trimmedAgency = agencyName.trim()

    const trimmedEmail = adminEmail.trim()



    if (!trimmedAgency || !trimmedEmail) {

      setError('Compila tutti i campi obbligatori')

      return

    }



    setLoading(true)

    try {

      const response = await fetch('/api/public/checkout/create-session', {

        method: 'POST',

        headers: { 'Content-Type': 'application/json' },

        body: JSON.stringify({

          planCode: selectedPlan,

          agencyName: trimmedAgency,

          adminEmail: trimmedEmail

        })

      })



      const data = await response.json().catch(() => null)

      if (!response.ok || !data?.success) {

        const message = data?.message ? String(data.message) : 'Errore durante la creazione della sessione di checkout'

        setError(message)

        return

      }



      const url = data?.data?.url

      if (typeof url === 'string' && url) {

        window.location.href = url

        return

      }



      setError('URL di checkout non valido restituito dal server')

    } catch {

      setError('Errore di rete durante la creazione della sessione di checkout')

    } finally {

      setLoading(false)

    }

  }



  if (mode === 'success') {

    const effectiveStatus: CheckoutStatus = checkoutStatus || 'PENDING'

    const primaryMessage =

      checkoutMessage ||

      (effectiveStatus === 'PROVISIONING'

        ? 'Stiamo configurando la tua istanza. Questa operazione puÒ² richiedere alcuni minuti.'

        : 'Stiamo preparando il tuo gestionale. Questa operazione puÒ² richiedere alcuni minuti.')

    const secondaryMessage =

      effectiveStatus === 'ERROR'

        ? "Se il problema persiste, contatta il supporto indicando l'email utilizzata in fase di acquisto."

        : 'Puoi tenere aperta questa pagina: verrai reindirizzato automaticamente non appena tutto sarÒ  pronto.'

    const badgeLabel =

      effectiveStatus === 'READY'

        ? 'Pronto'

        : effectiveStatus === 'PROVISIONING'

          ? 'Provisioning in corso'

          : effectiveStatus === 'ERROR'

            ? 'Errore'

            : 'In attesa'

    const badgeColor =

      effectiveStatus === 'READY'

        ? '#22c55e'

        : effectiveStatus === 'PROVISIONING'

          ? '#eab308'

          : effectiveStatus === 'ERROR'

            ? '#ef4444'

            : '#3b82f6'

    const iconBackground = effectiveStatus === 'ERROR' ? '#fee2e2' : '#dcfce7'

    const iconSymbol = effectiveStatus === 'ERROR' ? '!' : 'âS'



    return (

