          paddingBottom: '0.9rem'

        }}>

          <h3 className="manus-contact-title" style={{ fontSize: '1.18rem', fontWeight: '600', margin: 0, color: '#f8fafc', lineHeight: 1.2, letterSpacing: '-0.01em' }}>

            Cambia password

          </h3>

          {!forceChange && (

            <button

              className="manus-contact-close"

              onClick={onClose}

              style={{

                background: 'none',

                border: 'none',

                fontSize: '1.1rem',

