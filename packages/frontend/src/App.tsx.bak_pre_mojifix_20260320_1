        setProvinceOptions([])

      })

  }, [])

  const INTERNAL_PRICE_TAG = '[INCARICO_PRICE:'
  const extractInternalAgencyPrice = (notesValue?: string | null): string => {
    if (!notesValue) return ''
    const match = notesValue.match(/\[INCARICO_PRICE:([0-9]+(?:\.[0-9]+)?)\]/)
