// Modal per creare/modificare immobili

function PropertyModal({

  property,

  onSave,

  onCancel,
  currentUserRole

}: {

  property: Property | null

  onSave: (property: Omit<Property, 'id' | 'createdAt'> & { submitForApproval?: boolean; isPublished?: boolean }) => Promise<void>

  onCancel: () => void

  currentUserRole?: 'SUPER_ADMIN' | 'AGENCY_ADMIN' | 'AGENT' | 'COLLABORATOR' | null

}) {

  const [isSubmitting, setIsSubmitting] = useState(false)

  const [activeStep, setActiveStep] = useState(1)

  const [uploadedImages, setUploadedImages] = useState<string[]>(property?.images || [])

  const [availableAgents, setAvailableAgents] = useState<Agent[]>([])

  const [portalRegistry, setPortalRegistry] = useState<PortalRegistryItem[]>([])

  const [provinceOptions, setProvinceOptions] = useState<ItalianProvince[]>([])

  const { token } = useAuthStore()
  const isAdminUser = currentUserRole === 'SUPER_ADMIN' || currentUserRole === 'AGENCY_ADMIN'



  useEffect(() => {

    const previousOverflow = document.body.style.overflow

    document.body.style.overflow = 'hidden'

    return () => {

      document.body.style.overflow = previousOverflow

    }

  }, [])



  // Carica gli agenti disponibili

  useEffect(() => {

    const fetchAgents = async () => {

      try {

        const headers: HeadersInit = token

          ? { Authorization: `Bearer ${token}` }

          : {}



        const response = await fetch('/api/agents?isActive=true', { headers })

        if (!response.ok) {

          console.error('Errore risposta /api/agents:', response.status)

          return

        }



        const agents = await response.json()

        if (Array.isArray(agents)) {

          setAvailableAgents(agents as Agent[])

        } else {

          console.error('Formato risposta /api/agents non valido', agents)

        }

      } catch (error) {

        console.error('Errore nel caricamento agenti:', error)

      }

    }



    fetchAgents()

  }, [token])



  useEffect(() => {

    const fetchPortals = async () => {

      try {

        const response = await fetch('/api/portals')

        const data = await response.json().catch(() => null)

        if (!data?.success) return

        const nextPortals = Array.isArray(data?.data?.portals) ? (data.data.portals as PortalRegistryItem[]) : []

        setPortalRegistry(nextPortals)

      } catch {}

    }

    fetchPortals()

  }, [])



  useEffect(() => {

