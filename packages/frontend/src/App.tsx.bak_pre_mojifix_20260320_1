  const [monthFilter, setMonthFilter] = useState<string>('all')

  const [dayFilter, setDayFilter] = useState<string>('all')

  const [typeFilter, setTypeFilter] = useState<string>('all')



  const sortedNotifications = [...notifications].sort((a, b) => {

    return new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()

  })



  const years = Array.from(

    new Set(

      sortedNotifications.map(n => new Date(n.createdAt).getFullYear().toString())

    )

  ).sort((a, b) => Number(b) - Number(a))



  const months = yearFilter === 'all'

    ? []

    : Array.from(

        new Set(

          sortedNotifications

            .filter(n => new Date(n.createdAt).getFullYear().toString() === yearFilter)

            .map(n => {

              const d = new Date(n.createdAt)

              const month = (d.getMonth() + 1).toString().padStart(2, '0')

              const label = d.toLocaleString('it-IT', { month: 'long' })

              return `${month}|${label}`

            })

        )

      ).sort((a, b) => Number(b.split('|')[0]) - Number(a.split('|')[0]))



  const days = yearFilter === 'all' || monthFilter === 'all'

    ? []

    : Array.from(

        new Set(

          sortedNotifications

            .filter(n => {

              const d = new Date(n.createdAt)

              const y = d.getFullYear().toString()

              const m = (d.getMonth() + 1).toString().padStart(2, '0')

              return y === yearFilter && m === monthFilter

            })

            .map(n => {

              const d = new Date(n.createdAt)

              return d.getDate().toString().padStart(2, '0')

            })

        )

      ).sort((a, b) => Number(b) - Number(a))



  const filteredNotifications = sortedNotifications.filter(n => {

    if (filter === 'unread' && n.isRead) return false

    const d = new Date(n.createdAt)

    const y = d.getFullYear().toString()

    const m = (d.getMonth() + 1).toString().padStart(2, '0')

    const day = d.getDate().toString().padStart(2, '0')

    if (yearFilter !== 'all' && y !== yearFilter) return false

    if (monthFilter !== 'all' && m !== monthFilter) return false

    if (dayFilter !== 'all' && day !== dayFilter) return false

    if (typeFilter !== 'all' && n.type !== typeFilter) return false

    if (isAdmin && selectedUserId) {

      if (selectedUserId !== 'ALL' && n.recipientId !== selectedUserId) return false

    }

    return true

  })



  const unreadCount = notifications.filter(n => !n.isRead).length

  const agentOptions = agents.filter(a => a.role === 'AGENT')

  const notificationTypes = Array.from(new Set(sortedNotifications.map(n => n.type))).sort()



  const getNotificationIcon = (type: string) => {

    switch (type) {

      case 'TASK_COMPLETED': return 'Ã¢Å“â€¦'

      case 'APPOINTMENT_CREATED': return 'Ã°Å¸â€œâ€¦'

      case 'APPOINTMENT_REMINDER': return 'Ã¢ÂÂ°'

      case 'MATCH_FOUND': return 'Ã°Å¸Å½Â¯'

      case 'PROPERTY_ADDED': return 'Ã°Å¸ÂÂ '

      case 'CLIENT_ADDED': return 'Ã°Å¸â€˜Â¤'

      default: return 'Ã°Å¸â€œÂ¢'

    }

  }



  const getNotificationColor = (type: string) => {

    switch (type) {

      case 'NEW_EVENT': return '#3b82f6'

      case 'EVENT_UPDATE': return '#f59e0b'

      case 'EVENT_CANCELLED': return '#ef4444'

      case 'EVENT_REMINDER': return '#10b981'

