  }, [location.pathname, isAuthenticated, navigate, userRole, onboardingChecked])



  useEffect(() => {

    if (!isAuthenticated || !token) return

    if (onboardingStep !== 3) return

    if (onboardingConfigLoaded) return

    loadOnboardingConfig()

  }, [isAuthenticated, token, onboardingStep, onboardingConfigLoaded])



  useEffect(() => {

    if (!isAuthenticated || !token || !refreshToken) return



    const parseJwtExpiryMs = (raw: string) => {

      try {

        const parts = raw.split('.')

        if (parts.length < 2) return null

        const base64 = parts[1].replace(/-/g, '+').replace(/_/g, '/')

        const padded = base64 + '='.repeat((4 - (base64.length % 4)) % 4)

        const json = JSON.parse(atob(padded))

        if (typeof json?.exp !== 'number') return null

        return json.exp * 1000

      } catch {

        return null

      }

    }



    const expiresAtMs = parseJwtExpiryMs(token)

    if (!expiresAtMs) return



    const refreshAtMs = expiresAtMs - 60_000

    const delayMs = Math.max(refreshAtMs - Date.now(), 0)



    const timeoutId = window.setTimeout(async () => {

      try {

        const response = await globalThis.fetch('/api/auth/refresh', {

          method: 'POST',

          headers: { 'Content-Type': 'application/json' },

          body: JSON.stringify({ refreshToken }),

          credentials: 'include',

        })

        const payload = await response.json().catch(() => null)

        if (!response.ok || !payload?.success) {

          logout()

          navigate('/login')

          return

        }



        const nextToken = payload?.data?.token

        const nextRefreshToken = payload?.data?.refreshToken

        if (!nextToken) {

          logout()

          navigate('/login')

          return

        }



        setTokens(String(nextToken), nextRefreshToken != null ? String(nextRefreshToken) : undefined)

      } catch {

        logout()

        navigate('/login')

      }

    }, delayMs)



    return () => window.clearTimeout(timeoutId)

  }, [isAuthenticated, token, refreshToken, logout, navigate, setTokens])



  // Fetch data when user is authenticated

  useEffect(() => {

    if (user && token) {

      fetchData()

    }

  }, [user, token])



  useEffect(() => {

    if (!isAuthenticated || !token) return

    if (currentPage !== 'portals' && currentPage !== 'portal-detail') return



