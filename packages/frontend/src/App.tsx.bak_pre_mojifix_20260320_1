        setAiOutputText(data.data?.text || '')

        return

      }



      if (aiAction === 'improve') {

        if (!aiInputText.trim()) {

          alert('Ã¢ÂÅ’ Inserisci un testo da migliorare')

          return

        }

        const response = await fetch('/api/ai/improve-message', {

